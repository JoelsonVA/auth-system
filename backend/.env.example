DB_HOST=localhost
DB_PORT=3306
DB_USER=freelancehub_user
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=freelancehub

JWT_SECRET=uma_chave_secreta
PORT=3000

FRONTEND_URL=http://localhost:3000
# Opcional: múltiplas origens separadas por vírgula (ex.: produção + localhost)
FRONTEND_URLS=

# Stripe (Premium)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_FREELANCER=
STRIPE_PRICE_ID_CLIENT=
STRIPE_SUCCESS_URL=http://localhost:3000/app?billing=success
STRIPE_CANCEL_URL=http://localhost:3000/app?billing=cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/app

# Pagamento de trabalhos (one-time)
# Opcional: se não definido, usa STRIPE_SUCCESS_URL / STRIPE_CANCEL_URL
STRIPE_JOB_SUCCESS_URL=http://localhost:3000/app
STRIPE_JOB_CANCEL_URL=http://localhost:3000/app

# Regras Premium (app)
# Freelancers não-Premium recebem notificações com atraso (em horas)
PREMIUM_FREELANCER_NOTIFICATION_DELAY_HOURS=24
# Jobs de clientes Premium recebem "boost" na ordenação (em horas)
JOB_PREMIUM_BOOST_HOURS=24
# Limite de trabalhos simultâneos para freelancer comum
FREELANCER_MAX_CONCURRENT_JOBS=3
